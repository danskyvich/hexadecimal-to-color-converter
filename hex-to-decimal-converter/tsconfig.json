{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@/components/*": ["./src/components/"],
      "@/lib/*": ["./src/libs/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/lib/utils": ["./src/libs/utils"]
    },
    "moduleResolution": "node16"
  }
}
